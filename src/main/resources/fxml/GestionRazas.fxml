<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0" prefWidth="780.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #3d8d7a; -fx-border-width: 1.5; -fx-border-radius: 15;" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.GestionRazasController">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
   <children>
      <!-- Title -->
      <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3d8d7a;" text="🐾 Gestión de Razas 🐾" />
      
      <!-- HBox Splitter -->
      <HBox spacing="25.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Left Side: Registration Form -->
            <VBox spacing="15.0" prefWidth="380.0">
               <children>
                  <GridPane hgap="12.0" vgap="12.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="90.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Label styleClass="ficha-label-key" text="Especie:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                           <children>
                              <ComboBox fx:id="cbEspecie" prefWidth="210.0" promptText="Selecciona especie" styleClass="combo-box" HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" onAction="#agregarEspecie" style="-fx-background-color: #3d8d7a; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold;" text="+">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Button>
                           </children>
                        </HBox>
                        
                        <Label styleClass="ficha-label-key" text="Nombre Raza:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="txtNombreRaza" prefWidth="250.0" promptText="Ej. Labrador" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>
                  
                  <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Label styleClass="ficha-label-key" text="Descripción de la Especie (Contexto General):" />
                        <TextArea fx:id="txtDescEspecie" editable="false" prefHeight="70.0" promptText="Información sobre la especie..." styleClass="editor-clinico" wrapText="true" VBox.vgrow="ALWAYS" />
                        
                        <Label styleClass="ficha-label-key" text="Descripción de la Raza (Alertas Clínicas):" />
                        <TextArea fx:id="txtDescRaza" prefHeight="70.0" promptText="Ej. Riesgo de braquicefalia, displasia..." styleClass="editor-clinico" wrapText="true" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
                  
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cerrar" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 20; -fx-cursor: hand;" text="Cancelar">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Button>
                        <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#guardar" style="-fx-background-color: #3d8d7a; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 25; -fx-cursor: hand; -fx-font-weight: bold;" text="Guardar" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <!-- Right Side: Registered Breeds Table -->
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="titulo" text="Razas Registradas" />
                  <TableView fx:id="tblRazasExistentes" styleClass="tabla-mascotas" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colNombre" prefWidth="130.0" text="Nombre Raza" />
                        <TableColumn fx:id="colDescripcion" prefWidth="190.0" text="Alertas Clínicas" />
                     </columns>
                     <placeholder>
                        <Label style="-fx-text-fill: #aaaaaa; -fx-font-style: italic;" text="Selecciona una especie para ver sus razas" />
                     </placeholder>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
