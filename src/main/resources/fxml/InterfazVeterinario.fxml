            <Region prefHeight="352.0" prefWidth="199.0" VBox.vgrow="ALWAYS" />
            <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button mnemonicParsing="false" styleClass="boton-verde" text="Cerrar Sesión">
                     <HBox.margin>
                        <Insets bottom="20.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </left>
   <center>
      <ScrollPane prefHeight="207.0" prefWidth="339.0" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
