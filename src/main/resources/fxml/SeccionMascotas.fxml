<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.MascotasController">
   <children>
      <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="20.0" style="-fx-background-color: #DFF5E1;" styleClass="recuadros-informacion" stylesheets="@estilos.css">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <!-- HEADER -->
                  <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="200.0" spacing="10.0">
                     <children>
                        <Label prefHeight="45.0" prefWidth="250.0" styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Mascotas" textFill="#3d8d7a">
                           <graphic>
                              <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../images/Icon_Mascotas.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />

                        <!-- SEARCH PILL -->
                        <HBox styleClass="busqueda-pill" stylesheets="@estilos.css" alignment="CENTER_LEFT" spacing="8">
                           <HBox.margin>
                              <Insets right="100.0" />
                           </HBox.margin>
                           <children>
                              <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../images/Icon_Mascotas.png" />
                                 </image>
                              </ImageView>
                              <TextField fx:id="txtBuscar" prefHeight="35.0" prefWidth="320.0"
                                         promptText="Buscar mascota o escanear collar..."
                                         style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-border-width: 0; -fx-font-size: 13px; -fx-font-family: 'Segoe UI';">
                                 <cursor>
                                    <Cursor fx:constant="TEXT" />
                                 </cursor>
                              </TextField>
                           </children>
                        </HBox>

                        <HBox fx:id="hboxPerfil" alignment="CENTER_RIGHT" onMouseClicked="#manejarClickPerfil" spacing="10" style="-fx-cursor: hand;">
                           <children>
                              <!-- Avatar circular -->
                              <ImageView fx:id="imgPerfilMascotas" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                                 <clip>
                                    <Circle centerX="20.0" centerY="20.0" radius="20.0" />
                                 </clip>
                              </ImageView>
                              <!-- Nombre y rol del usuario -->
                              <VBox alignment="CENTER_LEFT" spacing="2.0">
                                 <children>
                                    <Label fx:id="lblNombreMascotas" style="-fx-font-family: System; -fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="Cargando..." />
                                    <Label fx:id="lblRolMascotas" style="-fx-font-family: System; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" text="" />
                                 </children>
                              </VBox>
                              <!-- Flecha indicadora de menú -->
                              <Label prefHeight="16.0" prefWidth="21.0" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="▾" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  
                  <!-- MAIN CONTENT (TABLE AND DETAILS) -->
                  <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                     <children>
                        <!-- TABLA Y RESULTADOS -->
                        <VBox spacing="10.0" styleClass="card" stylesheets="@estilos.css" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="titulo" stylesheets="@estilos.css" text="Resultados de búsqueda" />
                              <ListView fx:id="listaMascotas"
                                        styleClass="lista-mascotas"
                                        stylesheets="@estilos.css"
                                        VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                        
                        <!-- PANEL DETALLES -->
                        <VBox fx:id="panelDetalle" prefWidth="380.0" spacing="12.0"
                              styleClass="detail-card" stylesheets="@estilos.css">
                           <children>

                              <!-- Título -->
                              <Label styleClass="titulo" stylesheets="@estilos.css" text="Ficha de la mascota" />

                              <!-- Avatar circular de la mascota -->
                              <HBox alignment="CENTER">
                                 <children>
                                    <ImageView fx:id="imgMascotaFicha" fitHeight="80.0" fitWidth="80.0"
                                               pickOnBounds="true" preserveRatio="true">
                                       <clip>
                                          <Circle centerX="40.0" centerY="40.0" radius="40.0" />
                                       </clip>
                                    </ImageView>
                                 </children>
                              </HBox>

                              <!-- Nombre + Badge de estado en la misma fila -->
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                     <Label fx:id="lblNombre"
                                           styleClass="ficha-label-value" stylesheets="@estilos.css"
                                           text="-"
                                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A4D42;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblEstadoFicha"
                                           styleClass="status-badge status-healthy"
                                           stylesheets="@estilos.css"
                                           text="Saludable" />
                                 </children>
                              </HBox>

                              <!-- ── Sección: Información General ───────────── -->
                              <Label styleClass="seccion-titulo" stylesheets="@estilos.css"
                                     text="INFORMACIÓN GENERAL" />

                              <GridPane hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="154.5999755859375"
                                                     minWidth="10.0" prefWidth="99.39996337890625" />
                                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="230.60003662109375"
                                                     minWidth="10.0" prefWidth="230.60003662109375" />
                                </columnConstraints>
                                <rowConstraints>
                                  <RowConstraints minHeight="10.0" prefHeight="28.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="28.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="28.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="28.0" vgrow="SOMETIMES" />
                                </rowConstraints>
                                 <children>
                                    <Label styleClass="ficha-label-key" stylesheets="@estilos.css" text="Especie:" />
                                    <Label fx:id="lblEspecie" styleClass="ficha-label-value" stylesheets="@estilos.css"
                                           text="-" GridPane.columnIndex="1" />

                                    <Label styleClass="ficha-label-key" stylesheets="@estilos.css" text="Raza:"
                                           GridPane.rowIndex="1" />
                                    <Label fx:id="lblRaza" styleClass="ficha-label-value" stylesheets="@estilos.css"
                                           text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                    <Label styleClass="ficha-label-key" stylesheets="@estilos.css" text="Edad:"
                                           GridPane.rowIndex="2" />
                                    <Label fx:id="lblEdad" styleClass="ficha-label-value" stylesheets="@estilos.css"
                                           text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                    <Label styleClass="ficha-label-key" stylesheets="@estilos.css" text="Propietario:"
                                           GridPane.rowIndex="3" />
                                    <Label fx:id="lblPropietario" styleClass="ficha-label-value" stylesheets="@estilos.css"
                                           text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                 </children>
                              </GridPane>

                              <!-- ── Sección: Registro Médico ───────────────── -->
                              <Label styleClass="seccion-titulo" stylesheets="@estilos.css"
                                     text="REGISTRO MÉDICO" />

                              <TextArea fx:id="txtHistorial" editable="false" prefHeight="150.0" prefWidth="200.0"
                                        styleClass="historial-area" stylesheets="@estilos.css"
                                        wrapText="true" VBox.vgrow="ALWAYS" />
                              <HBox fx:id="containerBotones" spacing="15.0">
                                 <children>
                                    <Button fx:id="btnGuardar" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                            style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-family: 'Segoe UI Bold'; -fx-font-size: 15px; -fx-background-radius: 15; -fx-pref-height: 40; -fx-cursor: hand;"
                                            text="Guardar cambios" HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnCancelar" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                            style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-family: 'Segoe UI Semibold'; -fx-font-size: 14px; -fx-background-radius: 15; -fx-pref-height: 40; -fx-cursor: hand;"
                                            text="Cancelar" HBox.hgrow="ALWAYS" />
                                 </children>
                                 <VBox.margin>
                                    <Insets top="20.0" />
                                 </VBox.margin>
                              </HBox>

                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
