<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="598.0" prefWidth="1105.0" style="-fx-background-color: #DFF5E1;" styleClass="recuadros-informacion" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.CitasController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="62.0" prefWidth="1110.0">
         <children>
            <Label prefHeight="45.0" prefWidth="342.0" styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Citas" textFill="#3d8d7a">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <graphic>
                  <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/Icon_Citas.png" />
                     </image>
                  </ImageView>
               </graphic>
               <HBox.margin>
                  <Insets left="10.0" />
               </HBox.margin>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </Label>
            <Region prefHeight="56.0" prefWidth="548.0" HBox.hgrow="ALWAYS" />
            <!-- ═══════ Perfil de Usuario - Citas ═══════ -->
            <HBox fx:id="contenedorPerfilCitas" alignment="CENTER_LEFT" spacing="10.0" style="-fx-cursor: hand;">

               <!-- Imagen circular del usuario -->
               <StackPane>
                  <ImageView fx:id="imgPerfilCitas" fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                     <clip>
                        <Circle centerX="22.5" centerY="22.5" radius="22.5" />
                     </clip>
                  </ImageView>
               </StackPane>

               <!-- Nombre y rol del usuario -->
               <VBox fx:id="vboxInfoCitas" alignment="CENTER_LEFT" spacing="2.0">
                  <Label fx:id="lblNombreCitas" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Dr. Emmanuel" />
                  <Label fx:id="lblRolCitas" style="-fx-font-size: 11px; -fx-text-fill: #888888;" text="Veterinario" />
               </VBox>

               <!-- Icono flecha hacia abajo -->
               <Label fx:id="iconFlechaCitas" prefHeight="15.0" prefWidth="39.0" style="-fx-font-size: 10px; -fx-text-fill: #AAAAAA;" text="▼" />

            </HBox>
         </children>
      </HBox>
      <ScrollPane fitToHeight="true" fitToWidth="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-color: #DFF5E1;" stylesheets="@estilos.css" VBox.vgrow="ALWAYS">
         <content>
            <GridPane hgap="20.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="517.0" prefWidth="1099.0" style="-fx-background-color: #DFF5E1;" vgap="20.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="56.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="44.0" prefWidth="100.0" />
               </columnConstraints>
                <rowConstraints>
                  <RowConstraints minHeight="200.0" vgrow="ALWAYS" />
                  <RowConstraints minHeight="200.0" vgrow="ALWAYS" />
                  <RowConstraints minHeight="200.0" vgrow="ALWAYS" />
                </rowConstraints>
               <children>
                  <AnchorPane fx:id="vboxSiguienteCita" prefHeight="200.0" prefWidth="200.0" styleClass="barra-lateral">
                     <children>
                        <Label styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Siguiente cita">
                           <padding>
                              <Insets left="25.0" top="5.0" />
                           </padding>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </Label>
                        <Button fx:id="bAccionCita" layoutX="433.0" layoutY="199.0" mnemonicParsing="false" onAction="#manejarAccionCita" styleClass="boton-transparente" text="Iniciar Consulta" AnchorPane.bottomAnchor="10.0" AnchorPane.rightAnchor="15.0" />
                     </children>
                     <GridPane.margin>
                        <Insets left="10.0" right="10.0" top="10.0" />
                     </GridPane.margin>
                  </AnchorPane>
                  <VBox fx:id="vboxDetallesClinicos" prefHeight="200.0" prefWidth="100.0" styleClass="barra-lateral" stylesheets="@estilos.css" GridPane.columnIndex="1">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                     <GridPane.margin>
                        <Insets right="10.0" top="10.0" />
                     </GridPane.margin>
                     <children>
                        <Label styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Detalles Clínicos">
                           <padding>
                              <Insets left="25.0" top="5.0" />
                           </padding>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </Label>
                     </children>
                  </VBox>
                  <VBox fx:id="txtNotasMedicas" prefHeight="200.0" prefWidth="100.0" styleClass="barra-lateral" stylesheets="@estilos.css" GridPane.rowIndex="1">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                     <GridPane.margin>
                        <Insets left="10.0" right="10.0" top="10.0" />
                     </GridPane.margin>
                     <children>
                        <Label styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Generar reporte">
                           <padding>
                              <Insets left="25.0" top="5.0" />
                           </padding>
                        </Label>
                        <javafx.scene.control.TextArea fx:id="txtReporteCita" prefHeight="100.0" prefWidth="200.0" promptText="Escribe aquí las notas médicas de la consulta..." />
                        <Button fx:id="btnGuardarReporte" mnemonicParsing="false" onAction="#guardarReporte" style="-fx-background-color: #3d8d7a; -fx-text-fill: white; -fx-cursor: hand;" text="Guardar Reporte" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
                  <VBox fx:id="vboxReportesGuardados" prefHeight="200.0" prefWidth="100.0" styleClass="barra-lateral" stylesheets="@estilos.css" GridPane.columnSpan="2" GridPane.rowIndex="2">
                     <GridPane.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </GridPane.margin>
                     <children>
                        <Label styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Historial de Reportes Guardados (Local)">
                           <padding>
                              <Insets bottom="10.0" left="25.0" top="5.0" />
                           </padding>
                        </Label>
                     </children>
                  </VBox>
                  <VBox fx:id="vboxSignosVitales" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="190.0" prefWidth="493.0" styleClass="barra-lateral" stylesheets="@estilos.css" GridPane.columnIndex="1" GridPane.rowIndex="1">
                     <children>
                        <Label styleClass="titulo-bienvenida" text="Signos Vitales">
                           <padding>
                              <Insets left="25.0" top="5.0" />
                           </padding>
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                        </Label>
                     </children>
                     <GridPane.margin>
                        <Insets right="10.0" top="10.0" />
                     </GridPane.margin>
                  </VBox>
               </children>
            </GridPane>
         </content>
      </ScrollPane>
   </children>
</VBox>
