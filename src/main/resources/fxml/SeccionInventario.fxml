<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="407.0" prefWidth="699.0" spacing="20" style="-fx-background-color: #DFF5E1;" styleClass="recuadros-informacion" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.InventarioController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="560.0">
         <children>
            <Label prefHeight="42.0" prefWidth="342.0" styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Inventario" textFill="#3d8d7a">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <graphic>
                  <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/Icon_Inventario.png" />
                     </image>
                  </ImageView>
               </graphic>
               <padding>
                  <Insets left="10.0" top="10.0" />
               </padding>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <!-- ═══════ Perfil de Usuario - Inventario ═══════ -->
            <HBox fx:id="contenedorPerfilInventario" alignment="CENTER_LEFT" prefHeight="42.0" prefWidth="202.0" spacing="10.0" style="-fx-cursor: hand;">

               <!-- Imagen circular del usuario -->
               <StackPane>
                  <ImageView fx:id="imgPerfilInventario" fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                     <clip>
                        <Circle centerX="22.5" centerY="22.5" radius="22.5" />
                     </clip>
                  </ImageView>
               </StackPane>

               <!-- Nombre y rol del usuario -->
               <VBox fx:id="vboxInfoInventario" alignment="CENTER_LEFT" spacing="2.0">
                  <Label fx:id="lblNombreInventario" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Dr. Emmanuel" />
                  <Label fx:id="lblRolInventario" style="-fx-font-size: 11px; -fx-text-fill: #888888;" text="Veterinario" />
               </VBox>

               <!-- Icono flecha hacia abajo -->
               <Label fx:id="iconFlechaInventario" prefHeight="15.0" prefWidth="33.0" style="-fx-font-size: 10px; -fx-text-fill: #AAAAAA;" text="▼" />
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <padding>
                  <Insets top="20.0" />
               </padding>

            </HBox>
         </children>
      </HBox>
      <VBox spacing="15.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
         </padding>
         <children>
            <Label styleClass="titulo" text="Catálogo de Productos y Medicamentos" textFill="#2c3e50">
               <font>
                  <javafx.scene.text.Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <javafx.scene.control.ScrollPane fitToWidth="true" style="-fx-background: #DFF5E1; -fx-background-color: transparent;" stylesheets="@estilos.css" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="vboxInventarioContainer" spacing="15.0" style="-fx-background-color: #DFF5E1;">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </content>
            </javafx.scene.control.ScrollPane>
            <HBox fx:id="btnControlInventario" alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <javafx.scene.control.Button mnemonicParsing="false" onAction="#mostrarDialogoAgregar" style="-fx-background-color: #3d8d7a; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Nuevo Producto" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
