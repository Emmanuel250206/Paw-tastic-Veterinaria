<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="407.0" prefWidth="699.0" spacing="20" style="-fx-background-color: #DFF5E1;" styleClass="recuadros-informacion" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.InventarioController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="560.0">
         <children>
            <Label prefHeight="42.0" prefWidth="342.0" styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Inventario" textFill="#3d8d7a">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <graphic>
                  <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/Icon_Inventario.png" />
                     </image>
                  </ImageView>
               </graphic>
               <padding>
                  <Insets left="10.0" top="10.0" />
               </padding>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <HBox fx:id="hboxPerfil" alignment="CENTER_RIGHT" onMouseClicked="#manejarClickPerfil" spacing="10" style="-fx-cursor: hand;">
               <children>
                  <!-- Avatar circular -->
                  <ImageView fx:id="imgPerfilInventario" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                     <clip>
                        <Circle centerX="20.0" centerY="20.0" radius="20.0" />
                     </clip>
                  </ImageView>
                  <!-- Nombre y rol del usuario -->
                  <VBox alignment="CENTER_LEFT" spacing="2.0">
                     <children>
                        <Label fx:id="lblNombreInventario" style="-fx-font-family: System; -fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="Cargando..." />
                        <Label fx:id="lblRolInventario" style="-fx-font-family: System; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" text="" />
                     </children>
                     <HBox.margin>
                        <Insets right="15.0" top="10.0" />
                     </HBox.margin>
                  </VBox>
                  <!-- Flecha indicadora de menú -->
                  <Label prefHeight="16.0" prefWidth="21.0" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="▾" />
               </children>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </HBox>
         </children>
      </HBox>
      <VBox spacing="15.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
         </padding>
         <children>
            <Label styleClass="titulo" text="Catálogo de Productos y Medicamentos" textFill="#2c3e50">
               <font>
                  <javafx.scene.text.Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <javafx.scene.control.ScrollPane fitToWidth="true" style="-fx-background: #DFF5E1; -fx-background-color: transparent;" stylesheets="@estilos.css" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="vboxInventarioContainer" spacing="15.0" style="-fx-background-color: #DFF5E1;">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </content>
            </javafx.scene.control.ScrollPane>
            <HBox fx:id="btnControlInventario" alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <javafx.scene.control.Button mnemonicParsing="false" onAction="#mostrarDialogoAgregar" style="-fx-background-color: #3d8d7a; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Nuevo Producto" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
