<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="650.0" prefWidth="1105.0" spacing="20" style="-fx-background-color: #DFF5E1;" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.InventarioController">
   <children>
      <!-- Cabecera -->
      <HBox alignment="CENTER_LEFT" prefHeight="50.0">
         <children>
            <Label prefHeight="42.0" prefWidth="342.0" styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Inventario" textFill="#3d8d7a">
               <graphic>
                  <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/Icon_Inventario.png" />
                     </image>
                  </ImageView>
               </graphic>
               <padding>
                  <Insets left="10.0" top="10.0" />
               </padding>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <HBox fx:id="hboxPerfil" alignment="CENTER_RIGHT" onMouseClicked="#manejarClickPerfil" spacing="10" style="-fx-cursor: hand;">
               <children>
                  <!-- Avatar circular -->
                  <ImageView fx:id="imgPerfilInventario" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                     <clip>
                        <Circle centerX="20.0" centerY="20.0" radius="20.0" />
                     </clip>
                  </ImageView>
                  <!-- Nombre y rol del usuario -->
                  <VBox alignment="CENTER_LEFT" spacing="2.0">
                     <children>
                        <Label fx:id="lblNombreInventario" style="-fx-font-family: System; -fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="Cargando..." />
                        <Label fx:id="lblRolInventario" style="-fx-font-family: System; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" text="" />
                     </children>
                  </VBox>
                  <!-- Flecha indicadora de menú -->
                  <Label prefHeight="16.0" prefWidth="21.0" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="▾" />
               </children>
               <padding>
                  <Insets right="10.0" top="10.0" />
               </padding>
            </HBox>
         </children>
      </HBox>

      <!-- Cuerpo Principal -->
      <VBox spacing="15.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
         </padding>
         <children>
            <!-- Contenedor Blanco con Sombras -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, 5);" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <!-- Fila de Acciones -->
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3d8d7a;" text="Catálogo de Productos y Medicamentos" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox fx:id="btnControlInventario" alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#abrirModalAgregarProducto" style="-fx-background-color: #3d8d7a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-cursor: hand;" text="Agregar Producto" />
                              <Button mnemonicParsing="false" onAction="#editarProductoSeleccionado" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-cursor: hand;" text="Editar Producto" />
                              <Button mnemonicParsing="false" onAction="#eliminarProductoSeleccionado" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-cursor: hand;" text="Eliminar Producto" />
                           </children>
                        </HBox>
                        <Button mnemonicParsing="false" onAction="#buscarProductoGlobal" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20 8 20; -fx-cursor: hand;" text="Buscar Global" />
                     </children>
                  </HBox>

                  <!-- Tabla de Inventario -->
                  <TableView fx:id="tablaInventario" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colCodigo" prefWidth="120.0" text="Código / SKU" />
                        <TableColumn fx:id="colNombre" prefWidth="180.0" text="Nombre del Producto" />
                        <TableColumn fx:id="colCategoria" prefWidth="140.0" text="Categoría" />
                        <TableColumn fx:id="colStock" prefWidth="110.0" text="Stock Actual" />
                        <TableColumn fx:id="colStockMinimo" prefWidth="110.0" text="Stock Mínimo" />
                        <TableColumn fx:id="colUnidad" prefWidth="100.0" text="Unidad" />
                        <TableColumn fx:id="colCosto" prefWidth="100.0" text="Costo Unitario" />
                        <TableColumn fx:id="colPrecio" prefWidth="100.0" text="Precio Venta" />
                        <TableColumn fx:id="colCaducidad" prefWidth="130.0" text="Caducidad" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                     <placeholder>
                        <Label style="-fx-text-fill: #aaaaaa; -fx-font-style: italic; -fx-font-size: 14px;" text="No hay productos en el catálogo" />
                     </placeholder>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</VBox>
