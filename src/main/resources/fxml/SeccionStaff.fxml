<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.StaffController">
   <children>
      <ScrollPane fitToHeight="true" fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox fx:id="vboxContenedor" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="407.0" prefWidth="699.0" spacing="15.0" style="-fx-background-color: #DFF5E1;" styleClass="recuadros-informacion" stylesheets="@estilos.css">
               <children>
                  <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="560.0">
                     <children>
                        <Label prefHeight="42.0" prefWidth="342.0" styleClass="titulo-bienvenida" stylesheets="@estilos.css" text="Staff" textFill="#3d8d7a">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                           <graphic>
                              <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../images/Icon_Staff.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
<!-- ═══════ Perfil de Usuario - Staff ═══════ -->
                        <HBox fx:id="contenedorPerfilStaff" alignment="CENTER_LEFT" spacing="10.0" style="-fx-cursor: hand;">

                           <!-- Imagen circular del usuario -->
                           <StackPane>
                              <ImageView fx:id="imgPerfilStaff" fitHeight="45.0" fitWidth="45.0"
                                         pickOnBounds="true" preserveRatio="true"
                                         style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                                 <clip>
                                    <Circle centerX="22.5" centerY="22.5" radius="22.5" />
                                 </clip>
                              </ImageView>
                           </StackPane>

                           <!-- Nombre y rol del usuario -->
                           <VBox fx:id="vboxInfoStaff" alignment="CENTER_LEFT" spacing="2.0">
                              <Label fx:id="lblNombreStaff" text="Dr. Emmanuel"
                                     style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                              <Label fx:id="lblRolStaff" text="Veterinario"
                                     style="-fx-font-size: 11px; -fx-text-fill: #888888;" />
                           </VBox>

                           <!-- Icono flecha hacia abajo -->
                           <Label fx:id="iconFlechaStaff" text="&#9660;"
                                  style="-fx-font-size: 10px; -fx-text-fill: #AAAAAA;" />

                        </HBox>
                     </children>
                  </HBox>
                  <VBox fx:id="vboxContenedor" prefHeight="200.0" prefWidth="100.0" VBox.vgrow="ALWAYS" />
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
