<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="stackPrincipal" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.VeterinarioController">
   <children>
      <BorderPane fx:id="bpPrincipal" prefHeight="728.0" prefWidth="1357.0" style="-fx-background-color: #9ED3A9;">
         <left>
            <VBox maxHeight="1.7976931348623157E308" prefWidth="150.0" styleClass="barra-lateral" stylesheets="@estilos.css" BorderPane.alignment="CENTER">
               <BorderPane.margin>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="90.0" />
               </BorderPane.margin>
               <children>
                  <ImageView fitHeight="200.0" fitWidth="199.0">
                     <image>
                        <Image url="@../images/logo_paw.png" />
                     </image>
                     <VBox.margin>
                        <Insets top="-90.0" />
                     </VBox.margin>
                  </ImageView>
                  <Button fx:id="bDashboard" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarVistaDashboard" prefHeight="38.0" prefWidth="91.0" styleClass="boton-menu" text="       Dashboard">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                     <graphic>
                        <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/Icon_Dashboard.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="bCitas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarVistaCitas" styleClass="boton-menu" text="       Registro">
                     <graphic>
                        <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/Icon_Citas.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <font>
                        <Font size="14.0" />
                     </font></Button>
                  <Button fx:id="bMascotas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarVistaMascotas" styleClass="boton-menu" text="       Citas">
                     <graphic>
                        <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/Icon_Mascotas.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <font>
                        <Font size="14.0" />
                     </font></Button>
                  <Button fx:id="bInventario" layoutX="10.0" layoutY="120.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarVistaInventario" prefHeight="38.0" prefWidth="91.0" styleClass="boton-menu" text="       Triaje">
                     <graphic>
                        <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/Icon_Inventario.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="bPuntoVenta" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarVistaPOS" styleClass="boton-menu" text="       Punto Venta">
                     <graphic>
                        <ImageView fitHeight="45.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/Icon_POS.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="bReportes" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarVistaReportes" styleClass="boton-menu" text="       Reportes">
                     <graphic>
                        <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/Icon_Reporte.png" />
                           </image>
                        </ImageView>
                     </graphic></Button>
                  <Button fx:id="bStaff" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#mostrarVistaStaff" styleClass="boton-menu" text="       Staff">
                     <graphic>
                        <ImageView fitHeight="45.0" fitWidth="41.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/Icon_Staff.png" />
                           </image></ImageView>
                     </graphic>
                  </Button>
                  <Region prefHeight="352.0" prefWidth="199.0" VBox.vgrow="ALWAYS" />
                  <VBox alignment="CENTER" spacing="0.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #3D8D7A; -fx-border-width: 1.5; -fx-border-radius: 12; -fx-padding: 10 20 10 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);">
                     <children>
                        <HBox alignment="CENTER" spacing="2.0">
                           <children>
                              <Label fx:id="lblClockHours" style="-fx-text-fill: #2F4F4F; -fx-font-size: 28px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="00" />
                              <Label fx:id="lblClockColon" style="-fx-text-fill: #2F4F4F; -fx-font-size: 28px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text=":" />
                              <Label fx:id="lblClockMinutes" style="-fx-text-fill: #2F4F4F; -fx-font-size: 28px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="00" />
                           </children>
                        </HBox>
                        <Label fx:id="lblClockDate" style="-fx-text-fill: #5D7B6F; -fx-font-size: 13px; -fx-font-weight: 500; -fx-font-family: 'Segoe UI';" text="Cargando..." />
                     </children>
                     <VBox.margin>
                        <Insets bottom="15.0" />
                     </VBox.margin>
                  </VBox>
                  <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Button fx:id="btnCerrarSesion" mnemonicParsing="false" onAction="#onCerrarSesionClick" prefHeight="53.0" prefWidth="182.0" styleClass="boton-verde" text="  Cerrar Sesión">
                           <HBox.margin>
                              <Insets bottom="20.0" />
                           </HBox.margin>
                           <graphic>
                              <ImageView fitHeight="33.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../images/Icon_Exit.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </left>
         <center>
            <ScrollPane prefHeight="728.0" prefWidth="1085.0" style="-fx-background-color: transparent; -fx-background: transparent;" BorderPane.alignment="CENTER" />
         </center>
      </BorderPane>
   </children>
</StackPane>
