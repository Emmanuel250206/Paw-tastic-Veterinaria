<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="728.0" prefWidth="1357.0" style="-fx-background-color: #deffcb;;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.aplicacion.controllers.VeterinarioController">
   <left>
      <VBox maxHeight="1.7976931348623157E308" prefWidth="150.0" styleClass="barra-lateral" stylesheets="@estilos.css" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="20.0" left="20.0" top="90.0" />
         </BorderPane.margin>
         <children>
            <ImageView fitHeight="200.0" fitWidth="199.0">
               <image>
                  <Image url="@../images/logoPaw.png" />
               </image>
               <VBox.margin>
                  <Insets top="-90.0" />
               </VBox.margin>
            </ImageView>
            <Button fx:id="bDashboard" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#gestionarSeleccion" styleClass="boton-menu" text="Dashboard">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Button>
            <Button fx:id="bCitas" alignment="CENTER" contentDisplay="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#gestionarSeleccion" styleClass="boton-menu" text="Citas" />
            <Button fx:id="bMascotas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#gestionarSeleccion" styleClass="boton-menu" text="Mascotas" />
